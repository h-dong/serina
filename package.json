{
  "name": "serina",
  "version": "2.0.0-alpha.3",
  "description": "Natural Language Parser for date and time in Javascript",
  "keywords": [
    "date-parser",
    "javascript",
    "javascript-library",
    "library",
    "natural-language-processing",
    "time-parsing"
  ],
  "homepage": "https://github.com/h-dong/serina#readme",
  "bugs": {
    "url": "https://github.com/h-dong/serina/issues"
  },
  "license": "MIT",
  "author": "Hao Dong (hey@hao.dev)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h-dong/serina.git"
  },
  "source": "./src/index.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/serina.module.js",
  "module": "./dist/serina.module.js",
  "types": "./dist/serina.d.ts",
  "unpkg": "./dist/serina.module.js",
  "exports": {
    ".": {
      "types": "./dist/serina.d.ts",
      "import": "./dist/serina.module.js",
      "default": "./dist/serina.module.js"
    }
  },
  "scripts": {
    "watch": "tsup --watch",
    "build": "tsup",
    "build:docs": "./scripts/build-doc.sh",
    "fix": "pnpm lint:fix && pnpm format:fix",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "typecheck:test": "tsc --project tsconfig.test.json --ignoreDeprecations 6.0"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "^4.1.5",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "browserslist": [
    "defaults and supports es6-module",
    "maintained node versions"
  ],
  "packageManager": "pnpm@10.33.2",
  "alias": {
    "locales": "./src/locales",
    "parsers": "./src/parsers",
    "patterns": "./src/patterns",
    "utils": "./src/utils",
    "parser": "./src/parser",
    "types": "./src/types"
  }
}
